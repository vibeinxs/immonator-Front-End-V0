
{
  "name": "Immonator Full Stack",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  "postCreateCommand": "git submodule update --init --recursive && npm install && cd backend && npm install",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    },
    "codespaces": {
      "repositories": {
        "vibeinxs/AI-agent-backend": {
          "permissions": "read-all"
        }
      }
    }
  }
}
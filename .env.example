# Backend API base URL used by lib/api.ts and lib/analyseApi.ts
# Set this in your deployment platform's environment variable settings
# (Vercel: Project Settings → Environment Variables)
#
# Local dev: copy this file to .env.local and fill in the value
# Production: set NEXT_PUBLIC_API_URL in your hosting platform; do NOT commit .env.production
#
# Example values:
#   Local:      http://localhost:8000
#   Production: https://web-production-61c120.up.railway.app
NEXT_PUBLIC_API_URL=
